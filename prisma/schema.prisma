

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// --- ENUMS ---
enum Role {
  STUDENT
  LANDLORD
}

enum PaymentPurpose {
  LISTING_FEE
  DEPOSIT
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
}

// --- MODELS ---

model User {
  id           String   @id @default(uuid()) @map("user_id")
  username     String   @unique
  email        String   @unique
  phone        String?
  role         String   @default("student")
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  profilePhoto String?  @map("profile_photo")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relationships
  landlordProfile LandlordProfile?
  rentalRequests  RentalRequest[]  @relation("StudentRequests")
  reviewsWritten  Review[]         @relation("StudentReviews")
  fraudReports    FraudReport[]    @relation("ReportedBy")
  contactReveals  ContactReveal[]  @relation("StudentReveals")
  payments        Payment[]

  @@map("users")
}

model LandlordProfile {
  id               String   @id @default(uuid()) @map("landlord_id")
  userId           String   @unique @map("user_id")
  trustScore       Int      @default(0) @map("trust_score")
  isPhoneVerified  Boolean  @default(false) @map("is_phone_verified")
  isIdVerified     Boolean  @default(false) @map("is_id_verified")
  isLandlordVerified Boolean @default(false) @map("is_landlord_verified")
  verificationStatus String  @default("pending") @map("verification_status")
  organisationName String?  @map("organisation_name")
  isOrganisation   Boolean  @default(false) @map("is_organisation")
  

  // Relationships
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@map("landlord_profiles")
}

model Listing {
  id                      String    @id @default(uuid()) @map("listing_id")
  landlordId              String    @map("landlord_id")
  title                   String
  description             String?   @db.Text
  price                   Decimal   @db.Decimal(10, 2)
  deposit                 Decimal?  @db.Decimal(10, 2)
  address                 String
  amenities               Json      @default("[]")
  bedroomType             String?   @map("bedroom_type")
  mainWalkingMinutes      Int?      @map("main_walking_min")
  chiromoWalkingMinutes   Int?      @map("chiromo_walking_min")
  parklandsWalkingMinutes Int?      @map("parklands_walking_min")
  status                  String    @default("draft")
  expiresAt               DateTime? @map("expires_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  //Coordinatefor Mapping
  latitude                Float?
  longitude               Float?

  // Relationships
  landlord       LandlordProfile @relation(fields: [landlordId], references: [id])
  photos         ListingPhoto[]
  payments       Payment[]
  rentalRequests RentalRequest[]
  reviews        Review[]
  fraudReports   FraudReport[]
  contactReveals ContactReveal[]

  @@map("listings")
  listingViews ListingView[]
}

model ListingView {
  id        String   @id @default(uuid())
  listingId String   @map("listing_id")
  userId    String?  @map("user_id") 
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
    @@index([userId])
  @@map("listing_views")
}

model RentalRequest {
  id                   String    @id @default(uuid())
  listingId            String    @map("listing_id")
  studentId            String    @map("student_id")
  status               String    @default("pending")
  moveInDate           DateTime  @map("move_in_date")
  message              String?   @db.Text
  amount               Decimal   @db.Decimal(10, 2)
  mpesaReference       String?   @map("mpesa_reference")
  mpesaPhone           String?   @map("mpesa_phone")
  paymentDate          DateTime? @map("payment_date")
  confirmationDeadline DateTime? @map("confirmation_deadline")
  confirmedAt          DateTime? @map("confirmed_at")
  respondedAt          DateTime? @map("responded_at")
  expiresAt            DateTime? @map("expires_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  // Relationships
  listing Listing @relation(fields: [listingId], references: [id])
  student User    @relation("StudentRequests", fields: [studentId], references: [id])

  @@map("rental_requests")
}

model Review {
  id        String   @id @default(uuid()) @map("review_id")
  listingId String   @map("listing_id")
  studentId String   @map("student_id")
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relationships
  listing Listing @relation(fields: [listingId], references: [id])
  student User    @relation("StudentReviews", fields: [studentId], references: [id])

  @@map("reviews")
}

model Payment {
  id                 String         @id @default(uuid()) @map("payment_id")
  userId             String         @map("user_id")
  listingId          String?        @map("listing_id")
  purpose            PaymentPurpose @map("purpose")
  amount             Decimal        @db.Decimal(10, 2)
  status             PaymentStatus  @default(PENDING)
  mpesaPhone         String         @map("mpesa_phone")
  mpesaReference     String?        @unique @map("mpesa_reference")
  checkoutRequestId  String?        @unique @map("checkout_request_id")
  merchantRequestId  String?        @unique @map("merchant_request_id")
  accountReference   String?        @map("account_reference")
  transactionDesc    String?        @map("transaction_desc")
  transactionDateRaw String?        @map("transaction_date_raw")
  resultCode         Int?           @map("result_code")
  resultDesc         String?        @map("result_desc")
  callbackPayload    Json?          @map("callback_payload")
  initiatedAt        DateTime       @default(now()) @map("initiated_at")
  confirmedAt        DateTime?      @map("confirmed_at")
  failedAt           DateTime?      @map("failed_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  // Relationships
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing? @relation(fields: [listingId], references: [id])

  @@index([userId])
  @@index([listingId])
  @@index([purpose])
  @@index([status])
  @@index([initiatedAt])

  @@map("payments")
}

model ListingPhoto {
  id           String   @id @default(uuid())
  listingId    String   @map("listing_id")
  photoUrl     String   @map("photo_url")
  isPrimary    Boolean  @default(false) @map("is_primary")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relationship
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_photos")
}

model FraudReport {
  id           String   @id @default(uuid()) @map("report_id")
  listingId    String   @map("listing_id")
  reportedById String   @map("reported_by")
  category     String
  reason       String   @db.Text
  evidenceUrls Json     @default("[]") @map("evidence_urls")
  visitedProperty Boolean @default(false) @map("visited_property")
  acknowledged Boolean @default(false)
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relationships
  listing    Listing @relation(fields: [listingId], references: [id])
  reportedBy User    @relation("ReportedBy", fields: [reportedById], references: [id])

  @@map("fraud_reports")
}

model Admin {
  id           String    @id @default(uuid())
  username     String    @unique
  email        String    @unique
  passwordHash String    @map("password_hash") 
  
  // Account status
  isActive     Boolean   @default(true) @map("is_active")
  
  // Basic tracking
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("admins") 
}

model ContactReveal {
  id         String   @id @default(uuid()) @map("reveal_id")
  listingId  String   @map("listing_id")
  studentId  String   @map("student_id")
  revealedAt DateTime @default(now()) @map("revealed_at")

  // Relationships
  listing Listing @relation(fields: [listingId], references: [id])
  student User    @relation("StudentReveals", fields: [studentId], references: [id])

  @@map("contact_reveals")
}
